# Claude Haiku API — captions and hashtag generation
ANTHROPIC_API_KEY=

# Runway — image-to-video generation for reels
RUNWAY_API_KEY=

# Supabase — public client config (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-side only, bypasses RLS (NEVER expose client-side)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — payment processing (server-side only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Creatomate — video reel generation
CREATOMATE_API_KEY=your_key_here
CREATOMATE_TEMPLATE_DAY1_JUST_LISTED=your_template_id_here

# Content package price in cents ($99.00 = 9900)
PACKAGE_PRICE_CENTS=9900
